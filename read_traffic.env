# ── Kết nối MikroTik ──────────────────────────────────────────────────────────
MK_IP=192.168.40.1
MK_USER=admin
MK_PASS=123

# ── Kết nối MQTT Broker (server backend) ──────────────────────────────────────
MQTT_BROKER=192.168.40.252
MQTT_PORT=1883

# ── Identity — phải khớp với tenant/vessel/edge đã seed trên server ────────────
TENANT_CODE=tenant-01
VESSEL_CODE=vessel-01
EDGE_CODE=remote_01

# ── Interval gửi telemetry (giây) ─────────────────────────────────────────────
TELEMETRY_INTERVAL=5

# ── Path đến bash script failover (tuỳ chọn) ──────────────────────────────────
# Uncomment và điền path thực khi đã cấu hình sshpass trên MCU
# COMMAND_HOOK=/opt/mcu/failover_hook.sh

# ── Cấu hình policy mặc định (dùng khi --apply, không có payload từ server) ───
VSAT_GATEWAY=10.18.150.225
STARLINK_GATEWAY=192.168.1.1

# Danh sách IP dùng VSAT (work), phân cách bằng dấu phẩy
# WORK_IPS=192.168.40.0/24

# Danh sách IP dùng Starlink (entertainment), phân cách bằng dấu phẩy
# ENTERTAINMENT_IPS=192.168.1.0/24
