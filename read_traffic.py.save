import time
import csv
import os
import subprocess
import json
import paho.mqtt.client as mqtt
from paho.mqtt.enums import CallbackAPIVersion # Thêm dòng này
from routeros_api import RouterOsApiPool

# --- THÔNG SỐ ---
MK_IP       = "10.0.0.1"
MK_USER     = "admin"
MK_PASS     = "123"
MQTT_BROKER = "192.168.40.252" 
MQTT_TOPIC  = "mcu/tnr13/vsl-001/edge-001/heartbeat"
MQTT_TOPIC  = "mcu/tnr13/vsl-001/edge-001/telemetry"

WATCH_PORTS = {
    'ether1-Starlink': 'P1-STARLINK',
    'ether2-VSAT':     'P2-VSAT',
    'ether3-LTE':      'P3-LTE',
    'ether4-MCU':      'P4-MCU',
    'ether5-USER':     'P5-USER'
}

BASE_DIR = os.path.dirname(os.path.abspath(__file__))
LOG_FILE = os.path.join(BASE_DIR, "traffic_log.csv")

# --- FIX LỖI MQTT CLIENT VERSION 2 ---
client = mqtt.Client(CallbackAPIVersion.VERSION2)

def connect_mqtt():
    try:
        # Timeout kết nối là 5s để tránh treo script nếu không thấy Hub
        client.connect(MQTT_BROKER, 1883, keepalive=60)
        client.loop_start()
        return True
    except:
        return False

def ping_check(host):
    try:
        output = subprocess.run(['ping', '-c', '1', '-W', '0.8', host], 
                                stdout=subprocess.PIPE, stderr=subprocess.PIPE)
        return "ONLINE" if output.returncode == 0 else "OFFLINE"
    except: return "ERROR"

def monitor():
    mqtt_ok = connect_mqtt()
    if not mqtt_ok:
        print("⚠️  MQTT Broker Offline. Script vẫn chạy nhưng không gửi được dữ liệu về Hub.")
    
    try:
        api_pool = RouterOsApiPool(MK_IP, username=MK_USER, password=MK_PASS, plaintext_login=True)
        api = api_pool.get_api()
        res_iface = api.get_resource('/interface')
        
        prev_data = {i['name']: i for i in res_iface.get() if i['name'] in WATCH_PORTS}
        prev_time = time.time()

        while True:
            time.sleep(1)
            curr_time = time.time()
            interval = curr_time - prev_time
            timestamp = time.strftime('%H:%M:%S')
            
            # Kiểm tra trạng thái mạng
            net_stat = ping_check("8.8.8.8")
            be_stat  = ping_check(MQTT_BROKER)

            try:
                current_data = {i['name']: i for i in res_iface.get() if i['name'] in WATCH_PORTS}
            except: continue

            # Chuẩn bị dữ liệu gửi MQTT
            payload = {
                "timestamp": time.strftime('%Y-%m-%d %H:%M:%S'),
                "internet": net_stat,
                "hub_vpn": be_stat,
                "data": []
            }

            print(f"\n📅 {time.strftime('%Y-%m-%d')} | 🕒 {timestamp}")
            print(f"📡 INTERNET: {net_stat} | 🔗 HUB VPN: {be_stat}")
            print("=" * 82)
            print(f"{'PORT':<12} | {'STATUS':<10} | {'TRAFFIC (kbps)':^26} | {'TOTAL (MB)':>12}")
            print("-" * 82)

            for name, label in WATCH_PORTS.items():
                if name in current_data:
                    iface = current_data[name]
                    is_up = iface.get('running') == 'true'
                    status_str = "✅ UP" if is_up else "❌ DOWN"

                    curr_rx, curr_tx = int(iface.get('rx-byte', 0)), int(iface.get('tx-byte', 0))
                    prev_rx, prev_tx = int(prev_data[name].get('rx-byte', 0)), int(prev_data[name].get('tx-byte', 0))

                    kbps_in = ((curr_rx - prev_rx) * 8) / (1024 * interval)
                    kbps_out = ((curr_tx - prev_tx) * 8) / (1024 * interval)
                    total_mb = (curr_rx + curr_tx) / (1024 * 1024)

                    # Đưa vào payload MQTT
                    payload["data"].append({
                        "p": label, "s": status_str, "in": round(kbps_in,1), "out": round(kbps_out,1), "t": round(total_mb,2)
                    })

                    # In ra màn hình Pi
                    traffic = f"⬇ {kbps_in:>8.1f} | ⬆ {kbps_out:>8.1f}"
                    print(f"{label:<12} | {status_str:<10} | {traffic} | {total_mb:>10.2f} MB")

            # Gửi MQTT
            if mqtt_ok:
                client.publish(MQTT_TOPIC, json.dumps(payload))

            prev_data, prev_time = current_data, curr_time

    except KeyboardInterrupt: print("\n👋 Stopped."); client.loop_stop()
    except Exception as e: print(f"❌ Error: {e}")
    finally:
        if 'api_pool' in locals(): api_pool.disconnect()

if __name__ == "__main__":
    monitor()
